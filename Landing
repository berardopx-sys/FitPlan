<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Tu plan de entrenamiento y nutrición personalizado — FitPlan">
<title>FitPlan — Tu Transformación Empieza Acá</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --black:  #0b0b0b;
  --gray-900: #111;
  --gray-800: #1a1a1a;
  --gray-700: #232323;
  --gray-500: #555;
  --gray-400: #777;
  --orange:  #ff6a00;
  --orange-glow: rgba(255,106,0,0.4);
  --orange-soft: rgba(255,106,0,0.12);
  --white:   #f0ece6;
  --text:    #d8d4ce;
  --green:   #25d366;
  --radius:  16px;
}
* { box-sizing:border-box; margin:0; padding:0; }
html { scroll-behavior:smooth; }
body { background:var(--black); color:var(--text); font-family:'Outfit',sans-serif; font-size:16px; line-height:1.6; overflow-x:hidden; }

/* BG */
.bg-fixed { position:fixed; inset:0; z-index:0; pointer-events:none; }
.bg-orb { position:absolute; border-radius:50%; filter:blur(120px); opacity:0.12; }
.bg-orb.o1 { width:600px;height:600px;background:var(--orange);top:-200px;right:-200px; }
.bg-orb.o2 { width:400px;height:400px;background:#a855f7;bottom:-100px;left:-100px; }

/* WRAPPER */
.wrap { position:relative;z-index:1;max-width:960px;margin:0 auto;padding:0 20px; }

/* NAV */
nav { padding:20px 0;display:flex;align-items:center;justify-content:space-between; }
.nav-logo { font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--white);letter-spacing:3px; }
.nav-logo span { color:var(--orange); }
.nav-cta { background:var(--orange);border:none;border-radius:10px;color:#000;cursor:pointer;font-family:'Outfit',sans-serif;font-size:14px;font-weight:700;padding:10px 22px;text-decoration:none;display:inline-block;transition:all .2s; }
.nav-cta:hover { background:#ff8533;transform:translateY(-1px); }

/* HERO */
.hero { padding:80px 0 60px;text-align:center; }
.hero-badge { display:inline-flex;align-items:center;gap:8px;background:var(--orange-soft);border:1px solid rgba(255,106,0,0.3);border-radius:30px;padding:8px 18px;font-size:12px;font-weight:700;color:var(--orange);letter-spacing:1px;text-transform:uppercase;margin-bottom:28px; }
.hero-badge .dot { width:6px;height:6px;background:var(--orange);border-radius:50%;animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1}50%{opacity:.3} }
.hero h1 { font-family:'Bebas Neue',sans-serif;font-size:clamp(56px,10vw,96px);line-height:0.9;color:var(--white);letter-spacing:3px;margin-bottom:24px; }
.hero h1 span { color:var(--orange); }
.hero-sub { font-size:clamp(16px,2.5vw,20px);color:var(--gray-400);max-width:540px;margin:0 auto 40px;line-height:1.6; }
.hero-actions { display:flex;gap:14px;justify-content:center;flex-wrap:wrap; }
.btn-primary { background:var(--orange);border:none;border-radius:14px;color:#000;cursor:pointer;font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;padding:18px 42px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;box-shadow:0 0 40px var(--orange-glow);transition:all .3s;animation:btnGlow 2s ease-in-out infinite; }
.btn-primary:hover { transform:scale(1.04); }
@keyframes btnGlow { 0%,100%{box-shadow:0 0 30px var(--orange-glow)}50%{box-shadow:0 0 50px var(--orange-glow),0 0 80px rgba(255,106,0,0.15)} }
.btn-secondary { background:transparent;border:1px solid rgba(255,255,255,0.15);border-radius:14px;color:var(--text);cursor:pointer;font-family:'Outfit',sans-serif;font-size:16px;font-weight:600;padding:18px 32px;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all .2s; }
.btn-secondary:hover { border-color:rgba(255,255,255,0.35);color:var(--white); }

/* SOCIAL PROOF */
.social-proof { display:flex;align-items:center;justify-content:center;gap:16px;margin-top:28px;flex-wrap:wrap; }
.social-item { display:flex;align-items:center;gap:6px;font-size:13px;color:var(--gray-400); }
.social-item strong { color:var(--white); }

/* FEATURES */
.features { padding:80px 0; }
.section-label { font-size:12px;font-weight:700;color:var(--orange);text-transform:uppercase;letter-spacing:2px;margin-bottom:14px; }
.section-title { font-family:'Bebas Neue',sans-serif;font-size:clamp(36px,6vw,52px);color:var(--white);letter-spacing:2px;margin-bottom:16px;line-height:1.1; }
.section-sub { font-size:16px;color:var(--gray-400);max-width:500px;line-height:1.6;margin-bottom:48px; }
.features-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px; }
.feature-card { background:var(--gray-900);border:1px solid rgba(255,255,255,0.06);border-radius:var(--radius);padding:24px;transition:border-color .2s; }
.feature-card:hover { border-color:rgba(255,106,0,0.25); }
.feature-icon { font-size:32px;margin-bottom:14px; }
.feature-title { font-size:17px;font-weight:700;color:var(--white);margin-bottom:8px; }
.feature-desc { font-size:13px;color:var(--gray-400);line-height:1.6; }

/* PARA EL ENTRENADOR */
.trainer-section { padding:80px 0; }
.trainer-grid { display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center; }
@media(max-width:700px) { .trainer-grid { grid-template-columns:1fr; } }
.trainer-list { display:flex;flex-direction:column;gap:16px; }
.trainer-item { display:flex;align-items:flex-start;gap:14px; }
.trainer-item-icon { width:40px;height:40px;border-radius:12px;background:var(--orange-soft);border:1px solid rgba(255,106,0,0.2);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;margin-top:2px; }
.trainer-item-title { font-size:15px;font-weight:700;color:var(--white);margin-bottom:4px; }
.trainer-item-desc { font-size:13px;color:var(--gray-400);line-height:1.5; }
.mock-panel { background:var(--gray-900);border:1px solid rgba(255,255,255,0.08);border-radius:20px;padding:20px;overflow:hidden; }
.mock-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:16px; }
.mock-logo { font-family:'Bebas Neue',sans-serif;font-size:18px;color:var(--white);letter-spacing:2px; }
.mock-logo span { color:var(--orange); }
.mock-badge { background:var(--green-soft,rgba(37,211,102,.12));color:var(--green);border:1px solid rgba(37,211,102,.25);border-radius:20px;padding:3px 10px;font-size:10px;font-weight:700; }
.mock-stats { display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px; }
.mock-stat { background:rgba(255,255,255,0.04);border-radius:10px;padding:10px;text-align:center; }
.mock-stat-val { font-family:'Bebas Neue',sans-serif;font-size:24px;color:var(--orange); }
.mock-stat-lbl { font-size:9px;color:var(--gray-400);text-transform:uppercase; }
.mock-alumno { background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:10px;margin-bottom:8px; }
.mock-avatar { width:32px;height:32px;border-radius:50%;background:rgba(255,106,0,0.15);border:1px solid rgba(255,106,0,0.3);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--orange);flex-shrink:0; }
.mock-alumno-name { font-size:12px;font-weight:700;color:var(--white);flex:1; }
.mock-alumno-tag { font-size:10px;background:var(--green-soft,rgba(37,211,102,.1));color:var(--green);padding:2px 8px;border-radius:10px; }

/* PLANES / CTA -->
.cta-section { padding:80px 0;text-align:center; }
.cta-box { background:linear-gradient(135deg,rgba(255,106,0,0.1),rgba(255,106,0,0.04));border:1px solid rgba(255,106,0,0.25);border-radius:24px;padding:52px 40px;max-width:600px;margin:0 auto; }
.cta-title { font-family:'Bebas Neue',sans-serif;font-size:clamp(40px,7vw,60px);color:var(--white);letter-spacing:2px;margin-bottom:16px;line-height:1; }
.cta-sub { font-size:16px;color:var(--gray-400);margin-bottom:32px;line-height:1.6; }
.cta-features { display:flex;flex-direction:column;gap:8px;margin-bottom:32px;text-align:left;max-width:320px;margin-left:auto;margin-right:auto; }
.cta-feat-item { display:flex;align-items:center;gap:10px;font-size:14px;color:var(--text); }
.cta-feat-item::before { content:'✓';color:var(--green);font-weight:900;font-size:14px;flex-shrink:0; }

/* FOOTER */
footer { border-top:1px solid rgba(255,255,255,0.06);padding:28px 0;text-align:center; }
.footer-logo { font-family:'Bebas Neue',sans-serif;font-size:22px;color:var(--gray-400);letter-spacing:3px;margin-bottom:6px; }
.footer-logo span { color:var(--orange); }
.footer-sub { font-size:12px;color:var(--gray-500); }

/* RESPONSIVE */
@media(max-width:600px) {
  .hero { padding:60px 0 40px; }
  .features { padding:60px 0; }
  .trainer-section { padding:60px 0; }
  .cta-section { padding:60px 0; }
  .cta-box { padding:36px 24px; }
}
</style>
</head>
